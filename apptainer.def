Bootstrap: docker
From: python:3.12-bookworm

%post
    set -eux

    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        zlib1g \
        libgmp10 \
        libmpfr6 \
        libmpc3 \
        libgfortran5

    update-ca-certificates

    GAMMABOARD_REPO="${GAMMABOARD_REPO:-https://github.com/alphal00p/gammaboard.git}"
    GAMMABOARD_REF="${GAMMABOARD_REF:-main}"
    PROJECT_DIR="/opt/gammaboard"
    WRAPPER_DIR="${PROJECT_DIR}/integrations/madnis"
    git clone "${GAMMABOARD_REPO}" "${PROJECT_DIR}"
    cd "${PROJECT_DIR}"
    git checkout "${GAMMABOARD_REF}"

    python -m pip install --root-user-action=ignore --no-cache-dir --upgrade pip setuptools wheel
    python -m pip install --root-user-action=ignore --no-cache-dir \
        --index-url https://download.pytorch.org/whl/cu124 \
        torch
    python -m pip install --root-user-action=ignore --no-cache-dir --no-build-isolation \
        "madnis @ git+https://github.com/madgraph-ml/madnis.git@main"
    python -m pip install --root-user-action=ignore --no-cache-dir --no-build-isolation \
        "gammaboard-process @ git+https://github.com/alphal00p/gammaboard.git@main#subdirectory=process_api/python"
    python -m pip install --root-user-action=ignore --no-cache-dir --no-build-isolation "${WRAPPER_DIR}"
    python - <<'PY'
import madnis
import madnis_sampler
import gammaboard_process
import run_sampler
print("python runtime import check ok")
PY

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export OMP_NUM_THREADS="${OMP_NUM_THREADS:-64}"
    export PYTHONUNBUFFERED=1
    export PYTHONPATH="/opt/gammaboard/integrations/madnis/src:${PYTHONPATH:-}"

%runscript
    exec "$@"

%test
    python - <<'PY'
import madnis
import madnis_sampler
import gammaboard_process
import run_sampler
print("python runtime ok")
PY
